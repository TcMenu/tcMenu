<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.input.KeyCodeCombination?>
<?import javafx.scene.layout.*?>
<BorderPane fx:id="rootPane" styleClass="background" 
            stylesheets="@tcmenu-extras.css" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.thecoderscorner.bmped.controller.MainWindowController">
   <center>
       <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
           <tabs>
               <Tab fx:id="homeTab" text="Home" />
               <Tab fx:id="fontEditorTab" text="Font Editor" />
               <Tab fx:id="bitmapEditorTab" text="Bitmap Editor" />
           </tabs>
       </TabPane>
   </center>
   <bottom>
       <HBox spacing="10">
           <Hyperlink onAction="#onTheCodersCorner" text="TheCodersCorner.com"/>
           <Hyperlink onAction="#onFollowTwitter" text="Follow Twitter"/>
           <Hyperlink onAction="#onFollowFacebook" text="Follow Facebook"/>
       </HBox>
   </bottom>
    <padding>
        <Insets top="0" left="10" right="10" bottom="10" />
    </padding>
</BorderPane>
